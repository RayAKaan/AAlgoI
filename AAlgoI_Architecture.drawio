        <mxCell id="lane_2" value="&lt;b&gt;2. PARSING &amp;amp; PROBLEM SPECIFICATION&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;startSize=30;horizontal=1;" parent="1" vertex="1">
