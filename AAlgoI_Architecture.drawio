        <mxCell id="e2_1" value="&lt;b&gt;Question Parser&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Shorthand expansion (30+ aliases)&lt;br&gt;Arrow syntax (A→D → pathfinding)&lt;br&gt;Keyword detection (16 domains)&lt;br&gt;Zero-shot DistilBERT (optional)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=11;" parent="lane_2" vertex="1">
          <mxGeometry x="30" y="35" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e2_2" value="&lt;b&gt;Constraint Extractor&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;speed / memory / accuracy /&lt;br&gt;stability / interpretability&lt;br&gt;priority: speed|accuracy|balanced&lt;br&gt;Parameter extraction (vector_size=N)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=11;" parent="lane_2" vertex="1">
          <mxGeometry x="320" y="35" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e2_3" value="&lt;b&gt;ProblemSpec&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Dataclass: problem_type / inputs /&lt;br&gt;outputs / constraints / objectives /&lt;br&gt;sub_problems / pipeline_order&lt;br&gt;16 ProblemType enums + to_vector()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=11;" parent="lane_2" vertex="1">
          <mxGeometry x="550" y="35" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e2_4" value="&lt;b&gt;Data Shape Inference&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Auto-detect problem type from data&lt;br&gt;Dict keys → pathfinding/optimization/ML&lt;br&gt;List[int] → sorting / 2D array → clustering&lt;br&gt;Tensor shape → ML / CV&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=11;" parent="lane_2" vertex="1">
          <mxGeometry x="810" y="35" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e2_5" value="&lt;b&gt;Objective Extractor&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;minimize / maximize direction&lt;br&gt;Metric: execution_time /&lt;br&gt;quality / memory / accuracy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=11;" parent="lane_2" vertex="1">
          <mxGeometry x="1070" y="35" width="170" height="70" as="geometry" />
        </mxCell>

