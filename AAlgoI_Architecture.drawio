        <!-- ================================================================ -->
        <!-- LANE 3: META-CONTROLLER / SELECTION ENGINE -->
        <!-- ================================================================ -->
        <mxCell id="lane_3" value="&lt;b&gt;3. SELECTION ENGINE — UNIVERSALMETA CONTROLLER&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;startSize=30;horizontal=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="370" width="2020" height="370" as="geometry" />
        </mxCell>

        <!-- KG Group -->
        <mxCell id="e3_g1" value="&lt;b&gt;🧠 Knowledge Graph (NetworkX MultiDiGraph)&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fff8e8;strokeColor=#d79b00;fontSize=11;fontStyle=1;startSize=26;" parent="lane_3" vertex="1">
          <mxGeometry x="25" y="35" width="370" height="300" as="geometry" />
        </mxCell>
        <mxCell id="e3_1a" value="&lt;b&gt;Nodes:&lt;/b&gt; Problem / Algorithm /&lt;br&gt;Pattern / Metric / Constraint" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g1" vertex="1">
          <mxGeometry x="20" y="40" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e3_1b" value="&lt;b&gt;Edges:&lt;/b&gt; SOLVED_BY / IS_A /&lt;br&gt;HAS_COMPLEXITY /&lt;br&gt;PERFORMS_BEST_WHEN /&lt;br&gt;APPLICABLE_TO / SIMILAR_TO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g1" vertex="1">
          <mxGeometry x="190" y="40" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e3_1c" value="&lt;b&gt;Candidate Filtering:&lt;/b&gt;&lt;br&gt;narrows RL action space to&lt;br&gt;semantically valid candidates" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g1" vertex="1">
          <mxGeometry x="20" y="105" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e3_1d" value="&lt;b&gt;Cross-Domain Search:&lt;/b&gt;&lt;br&gt;traverses up to 4 hops to&lt;br&gt;find alternative algorithms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g1" vertex="1">
          <mxGeometry x="190" y="105" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e3_1e" value="&lt;b&gt;Fallback Alternatives:&lt;/b&gt;&lt;br&gt;pattern-sibling search&lt;br&gt;(same IS_A = similar algo)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g1" vertex="1">
          <mxGeometry x="20" y="170" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e3_1f" value="&lt;b&gt;Explain Path:&lt;/b&gt;&lt;br&gt;shortest semantic path from&lt;br&gt;problem node → algorithm node" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g1" vertex="1">
          <mxGeometry x="190" y="170" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- RL Agent Group -->
        <mxCell id="e3_g2" value="&lt;b&gt;🤖 RL Agent (PPO + Attention Head)&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fff8e8;strokeColor=#d79b00;fontSize=11;fontStyle=1;startSize=26;" parent="lane_3" vertex="1">
          <mxGeometry x="425" y="35" width="380" height="300" as="geometry" />
        </mxCell>
        <mxCell id="e3_2a" value="&lt;b&gt;State Encoder:&lt;/b&gt;&lt;br&gt;42-dim vector encoding:&lt;br&gt;data_size(log) + pattern flags +&lt;br&gt;uniqueness + distribution +&lt;br&gt;system state + 16-type one-hot +&lt;br&gt;6 constraints + size flags" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g2" vertex="1">
          <mxGeometry x="20" y="40" width="175" height="65" as="geometry" />
        </mxCell>
        <mxCell id="e3_2b" value="&lt;b&gt;Attention Policy Head:&lt;/b&gt;&lt;br&gt;Q = Wq·state | K = Wk·algo_emb&lt;br&gt;scores = Q·K^T/√d&lt;br&gt;π(a) = softmax(scores)&lt;br&gt;Variable-size action space" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g2" vertex="1">
          <mxGeometry x="200" y="40" width="170" height="65" as="geometry" />
        </mxCell>
        <mxCell id="e3_2c" value="&lt;b&gt;Algorithm Embeddings:&lt;/b&gt;&lt;br&gt;64-dim learnable vectors&lt;br&gt;New algorithms = new embeddings&lt;br&gt;No retraining needed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g2" vertex="1">
          <mxGeometry x="20" y="118" width="175" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e3_2d" value="&lt;b&gt;3-Stage Pre-training:&lt;/b&gt;&lt;br&gt;1. Supervised Boot (20k iters)&lt;br&gt;2. RL Curriculum (5k iters)&lt;br&gt;3. Self-Play (adversarial)&lt;br&gt;→ pretrained_v1.pt (0.41MB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g2" vertex="1">
          <mxGeometry x="200" y="118" width="170" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e3_2e" value="&lt;b&gt;Online PPO Training:&lt;/b&gt;&lt;br&gt;Actor-Critic with advantage&lt;br&gt;Store transitions → train every 64&lt;br&gt;Updates algo embeddings via SGD" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g2" vertex="1">
          <mxGeometry x="20" y="186" width="175" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e3_2f" value="&lt;b&gt;Gymnasium Env:&lt;/b&gt;&lt;br&gt;AAlgoIEnv: state_dim=200&lt;br&gt;action=Discrete(num_algos)&lt;br&gt;AdaptiveRewardShaper&lt;br&gt;ContextEngine integration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g2" vertex="1">
          <mxGeometry x="200" y="186" width="170" height="55" as="geometry" />
        </mxCell>

        <!-- Scoring + Bandit Group -->
        <mxCell id="e3_g3" value="&lt;b&gt;📊 Scoring Selector &amp;amp; UCB1 Bandit&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fff8e8;strokeColor=#d79b00;fontSize=11;fontStyle=1;startSize=26;" parent="lane_3" vertex="1">
          <mxGeometry x="835" y="35" width="340" height="300" as="geometry" />
        </mxCell>
        <mxCell id="e3_3a" value="&lt;b&gt;Semantic Scoring:&lt;/b&gt;&lt;br&gt;name match (×15) + tag match (×5)&lt;br&gt;best_for match (×8) + pattern (×3)&lt;br&gt;action penalty (×−20) if misaligned" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g3" vertex="1">
          <mxGeometry x="20" y="40" width="150" height="65" as="geometry" />
        </mxCell>
        <mxCell id="e3_3b" value="&lt;b&gt;UCB1 Bandit:&lt;/b&gt;&lt;br&gt;epsilon-greedy: starts 0.2→0.05&lt;br&gt;explore best candidate vs. random&lt;br&gt;tracks per-algorithm reward avg" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g3" vertex="1">
          <mxGeometry x="175" y="40" width="150" height="65" as="geometry" />
        </mxCell>
        <mxCell id="e3_3c" value="&lt;b&gt;Confidence Thresholds:&lt;/b&gt;&lt;br&gt;RL &lt; 50% → scoring override&lt;br&gt;RL &lt; 40% → LLM synthesis trigger&lt;br&gt;explore_threshold = 0.3−similarity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g3" vertex="1">
          <mxGeometry x="20" y="120" width="150" height="65" as="geometry" />
        </mxCell>
        <mxCell id="e3_3d" value="&lt;b&gt;History-Based Selection:&lt;/b&gt;&lt;br&gt;similar context KB recall&lt;br&gt;weighted voting from past&lt;br&gt;cosine similarity matching" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g3" vertex="1">
          <mxGeometry x="175" y="120" width="150" height="65" as="geometry" />
        </mxCell>

        <!-- LLM + Synthesizer Group -->
        <mxCell id="e3_g4" value="&lt;b&gt;🧬 LLM Adapter &amp;amp; Algorithm Synthesizer&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fff8e8;strokeColor=#d79b00;fontSize=11;fontStyle=1;startSize=26;" parent="lane_3" vertex="1">
          <mxGeometry x="1205" y="35" width="380" height="300" as="geometry" />
        </mxCell>
        <mxCell id="e3_4a" value="&lt;b&gt;LLM Adapter (Ollama):&lt;/b&gt;&lt;br&gt;phi3:mini default / llama.cpp alt&lt;br&gt;analyze_context() for advice&lt;br&gt;confidence &lt; 0.4 → query LLM&lt;br&gt;LLM suggests algorithm + reason" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g4" vertex="1">
          <mxGeometry x="15" y="40" width="175" height="65" as="geometry" />
        </mxCell>
        <mxCell id="e3_4b" value="&lt;b&gt;Algorithm Synthesizer:&lt;/b&gt;&lt;br&gt;Cascade:&lt;br&gt;1. Template match →&lt;br&gt;2. Transfer learning →&lt;br&gt;3. LLM code generation →&lt;br&gt;4. Primitive composition" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g4" vertex="1">
          <mxGeometry x="195" y="40" width="175" height="65" as="geometry" />
        </mxCell>
        <mxCell id="e3_4c" value="&lt;b&gt;24 Primitives Library:&lt;/b&gt;&lt;br&gt;iterate / map / filter / reduce / scan /&lt;br&gt;partition / binary_search / linear_search /&lt;br&gt;greedy / dp / gradient_descent /&lt;br&gt;quicksort / mergesort / heapsort /&lt;br&gt;bfs / dfs / interpolation_search /&lt;br&gt;two_pointer / sliding_window /&lt;br&gt;topo_sort / union_find / backtracking /&lt;br&gt;random_search / lcs / rabin_karp" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=8;" parent="e3_g4" vertex="1">
          <mxGeometry x="15" y="115" width="175" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e3_4d" value="&lt;b&gt;AST Optimizer:&lt;/b&gt;&lt;br&gt;3 optimization passes on source:&lt;br&gt;1. @lru_cache injection&lt;br&gt;2. Listcomp conversion&lt;br&gt;3. Loop fusion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g4" vertex="1">
          <mxGeometry x="195" y="115" width="175" height="80" as="geometry" />
        </mxCell>
        <mxCell id="e3_4e" value="&lt;b&gt;Sandboxed Executor:&lt;/b&gt;&lt;br&gt;create_sandboxed_module()&lt;br&gt;execute_sandboxed()&lt;br&gt;benchmark_sandboxed()&lt;br&gt;Safe untrusted code execution" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g4" vertex="1">
          <mxGeometry x="15" y="210" width="175" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e3_4f" value="&lt;b&gt;Prompt Builder:&lt;/b&gt;&lt;br&gt;build_synthesis_prompt()&lt;br&gt;Converts ProblemSpec → LLM prompt&lt;br&gt;Includes baseline algorithm context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" parent="e3_g4" vertex="1">
          <mxGeometry x="195" y="210" width="175" height="55" as="geometry" />
        </mxCell>

        <!-- Fallback Chain -->
        <mxCell id="e3_5" value="&lt;b&gt;🛡️ Fallback Chain:&lt;/b&gt; identity → safe_sort → quicksort → bfs_path → greedy_knapsack" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" parent="lane_3" vertex="1">
          <mxGeometry x="1610" y="240" width="380" height="30" as="geometry" />
        </mxCell>

        <!-- ================================================================ -->
        <!-- LANE 4: ALGORITHM REGISTRY -->
        <!-- ================================================================ -->
        <mxCell id="lane_4" value="&lt;b&gt;4. ALGORITHM REGISTRY — 45+ Algorithms&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;startSize=30;horizontal=1;" parent="1" vertex="1">
