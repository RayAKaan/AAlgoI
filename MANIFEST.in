# Include essential source
include pipeline.py
include pyproject.toml
include README.md
include LICENSE

# Include packages
recursive-include aalgoi *.py
recursive-include core *.py
recursive-include algorithms *.py
recursive-include interface *.py

# Exclude everything else
recursive-exclude checkpoints *
recursive-exclude tests *
recursive-exclude training *
prune checkpoints
prune tests
prune training

# Exclude dev files
exclude main.py
exclude demo.py
exclude verify_build.py
exclude examples.py
exclude setup.cfg
exclude CHEATSHEET.md

# Exclude build artifacts
global-exclude __pycache__
global-exclude *.pyc
global-exclude *.pyo
