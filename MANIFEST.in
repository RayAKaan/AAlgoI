# Include essential source
# include pipeline.py  -- moved under aalgoi/
include pyproject.toml
include README.md
include LICENSE

# Include packages
recursive-include aalgoi *.py
recursive-include aalgoi/core *.py
recursive-include aalgoi/algorithms *.py
recursive-include interface *.py

# Exclude everything else
recursive-exclude checkpoints *
recursive-exclude tests *
recursive-exclude training *
recursive-exclude examples *
recursive-exclude docs *
prune checkpoints
prune tests
prune training
prune examples
prune docs

# Exclude dev files
exclude scripts/main.py
exclude scripts/verify_build.py
exclude scripts/run_attention_verify.py
exclude setup.cfg

# Exclude build artifacts
global-exclude __pycache__
global-exclude *.pyc
global-exclude *.pyo
